{
  "name": "flash-sale",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "license": "UNLICENSED",
  "scripts": {
    "build": "turbo run build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "dev": "turbo run dev --parallel --filter=@flash-sale/api-gateway --filter=@flash-sale/order-worker --filter=@flash-sale/notification-service",
    "lint": "turbo run lint",
    "test": "npm run test:all",
    "test:unit": "jest --runInBand --testPathIgnorePatterns=integration\\.spec\\.ts$",
    "test:integration": "npm run test:integration:redis && npm run test:integration:postgres",
    "test:integration:redis": "node scripts/run-redis-integration-tests.mjs",
    "test:integration:postgres": "node scripts/run-postgres-integration-tests.mjs",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:load": "esbuild load-tests/ticket-burst-test.ts --bundle --outfile=load-tests/dist/test.js --platform=node --external:k6 --external:k6/http && k6 run load-tests/dist/test.js",
    "turbo": "turbo"
  },
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@bull-board/nestjs": "^7.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^11.0.1",
    "bullmq": "^5.76.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/k6": "^1.7.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.9.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@db/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@lib/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@redis/redis(|/.*)$": "<rootDir>/libs/redis/src/$1"
    }
  }
}
